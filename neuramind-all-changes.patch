+                    services.neuraMindController?.toggle()
+                },
+                onOpenDebug: {
+                    services.debugController?.toggle()
+                }
+            )
+        } else {
+            VStack(spacing: 12) {
+                Image(systemName: "exclamationmark.triangle")
+                    .font(.title2)
+                    .foregroundStyle(.secondary)
